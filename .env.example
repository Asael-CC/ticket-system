# Database - Railway proporcionará DATABASE_URL automáticamente
# Local development
DATABASE_URL="postgresql://postgres:password@localhost:5432/ticket_system?schema=public"

# JWT Secret - Genera una clave fuerte para producción
# Ejemplo: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Node Environment
NODE_ENV="development"

# Slack Integration (opcional)
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
SLACK_SIGNING_SECRET="your-slack-signing-secret"
SLACK_CHANNEL_ID="CXXXXXXXX"  # Canal donde se enviarán notificaciones

# Frontend URL (para CORS)
FRONTEND_URL="http://localhost:5173"

# API Port
PORT=3001
